<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PerfilAlumnoMVVM.Views.DetallePage">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">

            <Image Source="{Binding ImagenUrl}"
                   HeightRequest="170"
                   WidthRequest="170"
                   HorizontalOptions="Center" />

            <Label Text="{Binding Nombre}"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="{Binding Edad, StringFormat='Edad: {0} años'}"
                   FontSize="16"
                   HorizontalOptions="Center" />

            <Frame Padding="10" BorderColor="LightGray">
                <Label Text="{Binding Descripcion}"
                       FontSize="14" />
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>